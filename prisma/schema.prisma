generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String   @id @default(cuid())
  name        String   @unique
  acronym     String   @default("")
  description String   @default("")
  contact     String   @default("")
  website     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model Event {
  id                    String   @id
  title                 String
  category              String
  host                  String
  organization          String
  eventType             String
  status                String
  startDate             DateTime @db.Date
  endDate               DateTime @db.Date
  startTime             String   @default("")
  endTime               String   @default("")
  location              String
  mapLink               String   @default("")
  targetParticipants    String   @default("")
  description           String   @default("")
  contactPerson         String   @default("")
  sourceFile            String   @default("")
  remarks               String   @default("")
  isMajorBlockingEvent  Boolean  @default(false)
  conflictEligible      Boolean  @default(true)
  dateType              String   @default("exact")
  deliveryMode          String   @default("unspecified")
  recordType            String   @default("event")
  parentEventId         String?
  relationType          String   @default("independent")
  participationRequired Boolean  @default(false)
  venueNormalized       String   @default("")
  hostNormalized        String   @default("")
  targetGroupNormalized String   @default("")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  parentEvent Event?  @relation("EventRelations", fields: [parentEventId], references: [id], onDelete: SetNull)
  childEvents Event[] @relation("EventRelations")

  conflictsAsA EventConflict[] @relation("ConflictEventA")
  conflictsAsB EventConflict[] @relation("ConflictEventB")

  @@index([startDate])
  @@index([endDate])
  @@index([category])
  @@index([status])
  @@index([organization])
  @@index([conflictEligible])
  @@index([parentEventId])
}

model EventConflict {
  id               String    @id @default(cuid())
  eventAId         String
  eventBId         String
  conflictType     String
  severity         String
  reasons          String    @default("[]")
  recommendation   String    @default("")
  resolutionStatus String    @default("unresolved")
  resolutionNotes  String    @default("")
  pairKey          String    @unique
  isAutoGenerated  Boolean   @default(true)
  resolvedBy       String    @default("")
  resolvedAt       DateTime?
  eventAUpdatedAt  DateTime?
  eventBUpdatedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  eventA Event @relation("ConflictEventA", fields: [eventAId], references: [id], onDelete: Cascade)
  eventB Event @relation("ConflictEventB", fields: [eventBId], references: [id], onDelete: Cascade)

  @@index([severity])
  @@index([resolutionStatus])
  @@index([conflictType])
  @@index([eventAId])
  @@index([eventBId])
}
